MOSPI_SEED_URLS=https://mospi.gov.in/press-releases,https://mospi.gov.in/reports
SCRAPER_MAX_PAGES=5
SCRAPER_DELAY_SECONDS=2.0
SCRAPER_CONCURRENCY=2
SCRAPER_USER_AGENT=MoSPI-Research-Bot/1.0
SCRAPER_MAX_RETRIES=3
DATABASE_URL=data/mospi.db
PDF_DOWNLOAD_DIR=data/raw/pdf
PROCESSED_DIR=data/processed
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNK_MIN_SIZE=100
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=data/processed/faiss.index
CHUNKS_PKL_PATH=data/processed/chunks.pkl
# LLaMA 3 via Groq (free hosted API — no local Ollama/Docker needed)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Legacy Ollama settings (only used for optional local/offline inference)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b-instruct-q4_0
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
RETRIEVAL_TOP_K=5
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=8501
LOG_LEVEL=INFO
LOG_FORMAT=json
