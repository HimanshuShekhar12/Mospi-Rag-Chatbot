MOSPI_SEED_URLS=https://mospi.gov.in/press-releases,https://mospi.gov.in/reports
SCRAPER_MAX_PAGES=5
SCRAPER_DELAY_SECONDS=2.0
SCRAPER_CONCURRENCY=2
SCRAPER_USER_AGENT=MoSPI-Research-Bot/1.0
SCRAPER_MAX_RETRIES=3
DATABASE_URL=data/mospi.db
PDF_DOWNLOAD_DIR=data/raw/pdf
PROCESSED_DIR=data/processed
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNK_MIN_SIZE=100
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=data/processed/faiss.index
CHUNKS_PKL_PATH=data/processed/chunks.pkl
# For Docker: use ollama (Docker service name)
OLLAMA_BASE_URL=http://ollama:11434

# For local development: use localhost
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b-instruct-q4_0
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
RETRIEVAL_TOP_K=5
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=8501
LOG_LEVEL=INFO
LOG_FORMAT=json
